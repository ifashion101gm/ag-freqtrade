# Freqtrade Server – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ─── Freqtrade API Credentials ───────────────────────────────────────
API_USERNAME=admin
API_PASSWORD=ChooseAStrongPassword123!
JWT_SECRET_KEY=GenerateAStrongRandomKeyHere

# ─── Vantage Markets MT5 Connection ──────────────────────────────────
# Log in to your Vantage MT5 terminal to find these values.
# Server examples: "Vantage-Demo" (demo) or "Vantage-Live" (live)
VANTAGE_MT5_LOGIN=12345678
VANTAGE_MT5_PASSWORD=YourMT5Password
VANTAGE_MT5_SERVER=Vantage-Demo

# ─── Bot Mode ────────────────────────────────────────────────────────
# Set to "true" for paper trading (no real orders), "false" for live
BOT_DRY_RUN=true
# Primary symbol to trade
BOT_SYMBOL=XAUUSD

# ─── Telegram Alerts (optional) ──────────────────────────────────────
# Create a bot via @BotFather and get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFabcdef
TELEGRAM_CHAT_ID=-1001234567890

# ─── GitHub Integration (optional) ───────────────────────────────────
# Personal Access Token – Required scope: repo
GITHUB_TOKEN=ghp_YOUR_PERSONAL_ACCESS_TOKEN_HERE
