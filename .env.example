# Freqtrade Server – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ─── Freqtrade API Credentials ───────────────────────────────────────
API_USERNAME=admin
API_PASSWORD=ChooseAStrongPassword123!
JWT_SECRET_KEY=GenerateAStrongRandomKeyHere

# ─── GitHub Integration (optional) ───────────────────────────────────
# Personal Access Token used by scripts/integrations to interact with
# the GitHub API (e.g., auto-deploy, release tagging).
# Required scope: repo
GITHUB_TOKEN=ghp_YOUR_PERSONAL_ACCESS_TOKEN_HERE
